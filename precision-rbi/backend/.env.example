# ============================================================================
# Precision RBI — environment configuration
# Copy this file to `.env` (cp .env.example .env) and fill in the values below.
# NOTHING in docker-compose.yml is hardcoded; every secret/IP/port lives here.
# ============================================================================

# --- Network identity --------------------------------------------------------
# The IP or hostname team members reach this server at. This is the value you
# type once into the extension Options page. On the dev box this is the wlan0 IP.
# Find it with: ip -4 addr show wlan0 | grep inet
SERVER_PUBLIC_HOST=10.225.244.10

# nginx listener ports (host side)
HTTP_PORT=80
HTTPS_PORT=443

# --- Risk thresholds (0-100) -------------------------------------------------
# score > ISOLATE_THRESHOLD  -> render in RBI container, stream pixels back
# score > BLOCK_THRESHOLD     -> hard block page, never rendered
ISOLATE_THRESHOLD=50
BLOCK_THRESHOLD=80
SCORE_CACHE_TTL=3600          # seconds; domain score cache TTL in redis

# --- SSL inspection bypass ---------------------------------------------------
# Comma-separated domains that break under MITM (cert-pinned apps, banking, etc.)
# These are passed through CONNECT-tunneled without decryption.
BYPASS_DOMAINS=update.googleapis.com,clients2.google.com,*.windowsupdate.com

# --- RBI session sizing ------------------------------------------------------
# NOTE: 512 MB does NOT fit a real Chromium+Xvfb+VNC session. 1024 MB is the
# honest floor. See ARCHITECTURE.md §4. Lower MAX_SESSIONS if the host swaps.
SESSION_MEM_MB=1024
SESSION_CPUS=0.5
HOST_PORT_MIN=6080            # dynamic host-port range for noVNC, per container
HOST_PORT_MAX=6180
MAX_SESSIONS=4                # hard cap so the host never OOMs (dev box reality)

# --- Session lifecycle timers ------------------------------------------------
HEARTBEAT_TIMEOUT_MS=30000    # no ping for this long -> watchdog kills container
WATCHDOG_INTERVAL_MS=10000    # how often the watchdog sweeps

# --- BDR alerting ------------------------------------------------------------
BDR_ALERT_WINDOW_MS=300000    # 5 min
BDR_ALERT_THRESHOLD=3         # N same-type events in window -> flag user

# --- WireGuard VPN -----------------------------------------------------------
WG_PORT=51820
PEER_COUNT=10                 # one peer config generated per team member
WG_SPLIT_TUNNEL=10.225.244.0/24   # only this subnet is routed through the VPN

# --- Admin console -----------------------------------------------------------
ADMIN_USER=admin
# CHANGE THIS. Generate one: openssl rand -base64 24
ADMIN_PASS=change-me-before-first-boot
HOST_TOTAL_MEM_MB=7380        # used by the capacity gauge (7.21 GiB ~= 7380 MiB)

# --- Misc --------------------------------------------------------------------
APP_VERSION=0.1.0
