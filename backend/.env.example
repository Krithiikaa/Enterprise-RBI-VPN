# =============================================================================
#  Enterprise RBI + VPN — Environment Configuration
#  Copy to ".env" and edit:   cp .env.example .env
#  NEVER commit the real .env to version control.
# =============================================================================

# ---- Edge / public entry point ----------------------------------------------
# Port nginx listens on (the host machine's IP + this port is what team members
# enter in the extension, e.g. 10.225.244.50:8080).
EDGE_HTTP_PORT=8080

# ---- Auth --------------------------------------------------------------------
# Shared bearer token validated by the session-broker. Generate a strong one:
#   openssl rand -hex 32
SESSION_TOKEN=408175467ebbb618ffa5b7dad4f83336e627d46ec82f618e00e62bafd3bece47

# ---- Capacity / resource policy (tuned for the Ryzen 3 7320U / ~7GiB dev box)-
# Hard ceiling on simultaneous remote browser sessions on THIS host.
MAX_CONCURRENT_SESSIONS=12
# Memory ceiling per browser container (MB). 380 keeps 12 sessions < ~4.5GiB.
SESSION_MEM_LIMIT_MB=380
# CPU quota per container in fractional cores (0.5 = half a core).
SESSION_CPU_QUOTA=0.5
# Shared-memory size per container (MB). Chromium needs >64MB to avoid crashes.
SESSION_SHM_MB=256
# Idle/absolute session lifetime before the reaper destroys it (seconds).
SESSION_TTL_SECONDS=1800

# ---- Browser image / network names ------------------------------------------
BROWSER_IMAGE=rbi-browser:latest
# Must match the resolved compose network name (see README STEP 1).
RBI_NETWORK_NAME=enterprise-rbi-vpn_rbi-net

# ---- Forward proxy (the "VPN" the Chrome extension routes through) -----------
PROXY_PORT=3128
# Optional Basic-auth on the proxy. Leave blank to disable auth.
PROXY_USER=
PROXY_PASS=
# Optional: chain the proxy to an upstream company VPN/proxy. Leave blank for
# direct egress from the host.
UPSTREAM_VPN_HOST=
UPSTREAM_VPN_PORT=

# ---- WireGuard (OS-level full-device VPN, optional) --------------------------
WG_PORT=51820
WG_SERVER_ADDRESS=10.13.13.1/24
# Generate with:  wg genkey
WG_SERVER_PRIVATE_KEY=change-me-server-private-key
# Semicolon-separated peer public keys + allowed IPs:
#   <pubkey>|10.13.13.2/32 ; <pubkey2>|10.13.13.3/32
WG_PEERS=

# ---- Logging -----------------------------------------------------------------
LOG_LEVEL=info
